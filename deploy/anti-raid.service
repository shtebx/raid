[Unit]
Description=Anti-raid Roblox Flask (gunicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/anti-raid
EnvironmentFile=-/etc/anti-raid.env
ExecStart=/opt/anti-raid/.venv/bin/gunicorn --config /opt/anti-raid/deploy/gunicorn.conf.py wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
